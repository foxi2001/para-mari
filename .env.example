# Vercel environment variables — copy these into Vercel project settings.
# Do NOT commit a real .env.local file with the real values.

# From Supabase: Settings -> API -> Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# From Supabase: Settings -> API -> Project API keys -> service_role  (the SECRET one)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# Choose your own. This is what unlocks /api/upload, /api/delete, /api/recrop.
# Used by the admin bar's password prompt.
ADMIN_PASSWORD=cambiame-por-algo-tuyo

# Optional: lock down the API to a specific origin (default = same-origin).
# Leave empty unless you call the API from a different domain.
# ALLOWED_ORIGIN=https://para-mari.vercel.app
